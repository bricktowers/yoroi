{
  "extends": ["@react-native-community", "prettier"],
  "rules": {
    "@babel/no-invalid-this": "off",
    "prettier/prettier": [
      "error",
      {
        "quoteProps": "consistent",
        "bracketSpacing": false,
        "singleQuote": true,
        "tabWidth": 2,
        "trailingComma": "all",
        "useTabs": false,
        "semi": false
      }
    ]
  },
  "overrides": [
    {
      "files": ["metro.config.js"],
      "parserOptions": {
        "requireConfigFile": false
      }
    }
  ]
}
